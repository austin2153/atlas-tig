          "datasource": {
            "type": "influxdb",
            "uid": "P951FEA4DE68E13C5"
          },
          "query": "-- 'cpu-total' filters to the aggregate across all cores, not per-core\n\n-- time spent running user processes\n-- time spent in kernel/OS\n-- time waiting for disk I/O\nSELECT mean(\"usage_user\") AS \"User\",\n       mean(\"usage_system\") AS \"System\",\n       mean(\"usage_iowait\") AS \"IOWait\"\nFROM \"cpu\"\n\n-- exclude per-core rows (cpu0, cpu1, etc.)\nWHERE (\"cpu\" = 'cpu-total')\n\n-- grafana injects the selected time range\n  AND $timeFilter\n\n-- bucket data into grafana's auto interval\n-- leave gaps as null instead of interpolating\nGROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "time_series"
        }
      ],
      "title": "CPU Usage (rocky-linux.atlas.local)",
      "type": "timeseries"
    },
