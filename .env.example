# InfluxDB Authentication Token
# Auto-generated by deploy.sh on first run - do not set manually
# INFLUXDB_TOKEN=your-token-here

# Grafana Admin Password (optional, defaults to 'admin')
# Uncomment to set a custom password:
# GRAFANA_ADMIN_PASSWORD=your-secure-password

# UniFi Monitoring (optional - only needed if using custom UniFi scripts)
# UNIFI_CONSOLE_ID=your-console-id
# UNIFI_API_KEY=your-api-key
